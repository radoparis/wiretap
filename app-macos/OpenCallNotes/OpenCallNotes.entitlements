<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  MVP runs in developer mode WITHOUT the App Sandbox so the app can spawn the
	  Python worker subprocess and read/write the recordings folder freely
	  (see ../../DECISIONS.md D10). A sandboxed, notarized build is future work.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.device.audio-input</key>
	<true/>
</dict>
</plist>
